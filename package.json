{
  "name": "repo-template-web-auth-rbac-angular",
  "version": "0.1.0",
  "private": true,
  "description": "Generalized auth + RBAC web template (Angular + TypeScript) with optional Electron shell.",
  "scripts": {
    "dev": "ng serve web --host 0.0.0.0 --port 4200",
    "build": "ng build web",
    "test": "ng test web --watch=false --browsers=ChromeHeadless",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "desktop:dev": "pnpm --filter desktop dev",
    "desktop:build": "pnpm --filter desktop build"
  },
  "dependencies": {
    "@angular/animations": "19.2.4",
    "@angular/common": "19.2.4",
    "@angular/compiler": "19.2.4",
    "@angular/core": "19.2.4",
    "@angular/forms": "19.2.4",
    "@angular/platform-browser": "19.2.4",
    "@angular/platform-browser-dynamic": "19.2.4",
    "@angular/router": "19.2.4",
    "rxjs": "7.8.1",
    "tslib": "2.8.1",
    "zone.js": "0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "19.2.5",
    "@angular/cli": "19.2.5",
    "@angular/compiler-cli": "19.2.4",
    "@types/node": "22.13.10",
    "@typescript-eslint/eslint-plugin": "8.26.0",
    "@typescript-eslint/parser": "8.26.0",
    "eslint": "9.21.0",
    "prettier": "3.5.2",
    "typescript": "5.8.2",
    "@types/jasmine": "5.1.5",
    "jasmine-core": "5.6.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0"
  },
  "packageManager": "pnpm@10.6.3"
}
